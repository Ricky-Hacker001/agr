# CLIENT ENVIRONMENT VARIABLES
#
# LOCAL DEVELOPMENT
# -----------------
# Leave VITE_API_URL unset (or point to localhost) for local dev.
# The api.ts client defaults to http://localhost:5000/api automatically.
#
# PRODUCTION (Render.com)
# -----------------------
# Set VITE_API_URL to your deployed server URL in Render environment settings
# OR in this file before building:
#
# VITE_API_URL=https://arg-academy-server.onrender.com/api

# Uncomment below for local development override:
# VITE_API_URL=http://localhost:5000/api
